# MongoDB connection string. Leave unset to use an in-memory dev database (auto-seeded).
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/digital-atelier

# Admin login credentials
ADMIN_EMAIL=admin@digitalatelier.com
ADMIN_PASSWORD=change-me

# Secret used to sign admin session tokens — set to a long random string in production
JWT_SECRET=dev-secret-change-me

PORT=4000
